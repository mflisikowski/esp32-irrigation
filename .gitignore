# ── ESP-IDF (firmware) ───────────────────────────────────────────────────────
# build/ i managed_components/ są regenerowane przez idf.py; sdkconfig jest
# generowany z sdkconfig.defaults (per-maszyna).
build/
managed_components/
sdkconfig
sdkconfig.old

# ── Web UI (Vite / Node) ─────────────────────────────────────────────────────
web/node_modules/
web/build/
web/dist/

# ── Obraz SPIFFS (generowany z web/build przez web_build) ─────────────────────
# Per CLAUDE.md: data/ to wynik builda web UI, nie edytować ręcznie.
data/

# ── PlatformIO (pozostałości po migracji z Arduino) ──────────────────────────
.pio/
.pioenvs/
.piolibdeps/

# ── Narzędzia agentowe / sesje (lokalne, nie część projektu) ─────────────────
.agents/
skills-lock.json
.opencode/
.omo/
.cache/
_bmad/
_bmad-output/

# ── Edytory / OS ─────────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
.zed/
